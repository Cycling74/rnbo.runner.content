                                                {
                                                    "box": {
                                                        "maxclass": "newobj",
                                                        "text": "in 2 @comment right",
                                                        "patching_rect": [ 813.0, 27.0, 119.0, 22.0 ],
                                                        "numinlets": 0,
                                                        "numoutlets": 1,
                                                        "id": "obj-gin2",
