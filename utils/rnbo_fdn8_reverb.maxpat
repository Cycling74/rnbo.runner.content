                                                    }
                                                },
                                                {
                                                    "box": {
                                                        "maxclass": "codebox",
                                                        "patching_rect": [ 44.0, 84.0, 788.0, 708.0 ],
                                                        "fontface": 0,
                                                        "numinlets": 2,
                                                        "numoutlets": 2,
                                                        "id": "obj-gcode",
                                                        "fontsize": 12.0,
                                                        "outlettype": [ "", "" ],
                                                        "fontname": "<Monospaced>",
                                                        "code": "/*\nStereo reverb for genexpr / gen~.\n\nInputs:\nin1 = left\nin2 = right\n\nParams:\npredelay_ms\nsize\ndecay_s\ndamping_hz\ndamping_amount\ninput_gain_db\ninput_lowshelf_hz\ninput_lowshelf_db\ndiffusion_ratio\nmod_depth_ms\nmod_rate_hz\nearly_level\nwidth\nmix\n\nOutputs:\nout1 = left\nout2 = right\n\nPrimary design reference:\n- Signalsmith Audio, \"Let's Write A Reverb\"\n  https://signalsmith-audio.co.uk/writing/2021/lets-write-a-reverb/\n\nImplementation notes:\n- Four 8-channel diffuser stages feed an 8-channel FDN.\n- A low-shelf shapes the wet input feed only.\n- The diffuser uses fixed permutations, polarity flips, and a normalized\n  8-point Hadamard transform after each delay stage.\n- The FDN uses Householder feedback mixing, RT60-derived feedback gains,\n  per-line damping, and subtle feedback-delay modulation.\n*/\n\ndelay_read_linear(buffer, writeIndex, delaySamples) {\n    readPosition = writeIndex - delaySamples; // sample wrap mode handles this already\n    return sample(buffer, readPosition, 0, boundmode=\"wrap\", index=\"samples\");\n}\n\none_pole_lowpass(inputSample, coeff, state) {\n    nextState = state + (1 - coeff) * (inputSample - state);\n    return nextState;\n}\n\nhadamard8(x0, x1, x2, x3, x4, x5, x6, x7) {\n    a0 = x0 + x1;\n    a1 = x0 - x1;\n    a2 = x2 + x3;\n    a3 = x2 - x3;\n    a4 = x4 + x5;\n    a5 = x4 - x5;\n    a6 = x6 + x7;\n    a7 = x6 - x7;\n\n    b0 = a0 + a2;\n    b1 = a1 + a3;\n    b2 = a0 - a2;\n    b3 = a1 - a3;\n    b4 = a4 + a6;\n    b5 = a5 + a7;\n    b6 = a4 - a6;\n    b7 = a5 - a7;\n\n    c0 = b0 + b4;\n    c1 = b1 + b5;\n    c2 = b2 + b6;\n    c3 = b3 + b7;\n    c4 = b0 - b4;\n    c5 = b1 - b5;\n    c6 = b2 - b6;\n    c7 = b3 - b7;\n\n    scale = 0.3535533905932738;\n    return c0 * scale, c1 * scale, c2 * scale, c3 * scale, c4 * scale, c5 * scale, c6 * scale, c7 * scale;\n}\n\nhouseholder8(x0, x1, x2, x3, x4, x5, x6, x7) {\n    averageTwice = (x0 + x1 + x2 + x3 + x4 + x5 + x6 + x7) * 0.25;\n    return x0 - averageTwice, x1 - averageTwice, x2 - averageTwice, x3 - averageTwice, x4 - averageTwice, x5 - averageTwice, x6 - averageTwice, x7 - averageTwice;\n}\n\nrt60_gain(delaySamples, rt60Samples) {\n    return exp(log(0.001) * (delaySamples / max(rt60Samples, 1)));\n}\n\nstereo_low_shelf(left, right, freq, gain) {\n    History input_shelf_x1_l(0);\n    History input_shelf_x2_l(0);\n    History input_shelf_y1_l(0);\n    History input_shelf_y2_l(0);\n    History input_shelf_x1_r(0);\n    History input_shelf_x2_r(0);\n    History input_shelf_y1_r(0);\n    History input_shelf_y2_r(0);\n    \n    shelf_phase = freq / samplerate;\n    shelf_cos = cycle(shelf_phase, index=\"phase\");\n    shelf_sin = cycle(shelf_phase - 0.25, index=\"phase\");\n    shelf_amp = pow(10, gain * 0.025);\n    shelf_beta = shelf_sin * sqrt(2 * shelf_amp);\n\n    shelf_b0 = shelf_amp * ((shelf_amp + 1) - ((shelf_amp - 1) * shelf_cos) + shelf_beta);\n    shelf_b1 = 2 * shelf_amp * ((shelf_amp - 1) - ((shelf_amp + 1) * shelf_cos));\n    shelf_b2 = shelf_amp * ((shelf_amp + 1) - ((shelf_amp - 1) * shelf_cos) - shelf_beta);\n    shelf_a0 = (shelf_amp + 1) + ((shelf_amp - 1) * shelf_cos) + shelf_beta;\n    shelf_a1 = -2 * ((shelf_amp - 1) + ((shelf_amp + 1) * shelf_cos));\n    shelf_a2 = (shelf_amp + 1) + ((shelf_amp - 1) * shelf_cos) - shelf_beta;\n\n    shelf_b0n = shelf_b0 / shelf_a0;\n    shelf_b1n = shelf_b1 / shelf_a0;\n    shelf_b2n = shelf_b2 / shelf_a0;\n    shelf_a1n = shelf_a1 / shelf_a0;\n    shelf_a2n = shelf_a2 / shelf_a0;\n\n    left_out = (shelf_b0n * left) + (shelf_b1n * input_shelf_x1_l) + (shelf_b2n * input_shelf_x2_l) - (shelf_a1n * input_shelf_y1_l) - (shelf_a2n * input_shelf_y2_l);\n    right_out = (shelf_b0n * right) + (shelf_b1n * input_shelf_x1_r) + (shelf_b2n * input_shelf_x2_r) - (shelf_a1n * input_shelf_y1_r) - (shelf_a2n * input_shelf_y2_r);\n\n    input_shelf_x2_l = input_shelf_x1_l;\n    input_shelf_x1_l = left;\n    input_shelf_y2_l = input_shelf_y1_l;\n    input_shelf_y1_l = left_out;\n\n    input_shelf_x2_r = input_shelf_x1_r;\n    input_shelf_x1_r = right;\n    input_shelf_y2_r = input_shelf_y1_r;\n    input_shelf_y1_r = right_out;\n\n    return left_out, right_out;\n}\n\nParam predelay_ms(20, min=0, max=200);\nParam size(1, min=0.1, max=10);\nParam decay_s(3, min=0.1, max=20);\nParam damping_hz(8000, min=1000, max=18000);\nParam damping_amount(1, min=0, max=1);\nParam input_gain_db(0, min=-24, max=24);\nParam input_lowshelf_hz(250, min=20, max=1000);\nParam input_lowshelf_db(0, min=-18, max=18);\nParam diffusion_ratio(0.75, min=0.1, max=4);\nParam mod_depth_ms(0.8, min=0, max=5);\nParam mod_rate_hz(0.18, min=0.01, max=2);\nParam early_level(0.25, min=0, max=1);\nParam width(1, min=0, max=2);\nParam mix(0.35, min=0, max=1);\nParam freeze(0, min=0, max=1);\nParam smooth_ms(20, min=1, max=1000);\n\nData predelay_left(65536);\nData predelay_right(65536);\n\nData diffuser_1_0(327680);\nData diffuser_1_1(327680);\nData diffuser_1_2(327680);\nData diffuser_1_3(327680);\nData diffuser_1_4(327680);\nData diffuser_1_5(327680);\nData diffuser_1_6(327680);\nData diffuser_1_7(327680);\n\nData diffuser_2_0(327680);\nData diffuser_2_1(327680);\nData diffuser_2_2(327680);\nData diffuser_2_3(327680);\nData diffuser_2_4(327680);\nData diffuser_2_5(327680);\nData diffuser_2_6(327680);\nData diffuser_2_7(327680);\n\nData diffuser_3_0(327680);\nData diffuser_3_1(327680);\nData diffuser_3_2(327680);\nData diffuser_3_3(327680);\nData diffuser_3_4(327680);\nData diffuser_3_5(327680);\nData diffuser_3_6(327680);\nData diffuser_3_7(327680);\n\nData diffuser_4_0(327680);\nData diffuser_4_1(327680);\nData diffuser_4_2(327680);\nData diffuser_4_3(327680);\nData diffuser_4_4(327680);\nData diffuser_4_5(327680);\nData diffuser_4_6(327680);\nData diffuser_4_7(327680);\n\nData fdn_0(524288);\nData fdn_1(524288);\nData fdn_2(524288);\nData fdn_3(524288);\nData fdn_4(524288);\nData fdn_5(524288);\nData fdn_6(524288);\nData fdn_7(524288);\n\nHistory predelay_write(0);\nHistory diffuser_write_1(0);\nHistory diffuser_write_2(0);\nHistory diffuser_write_3(0);\nHistory diffuser_write_4(0);\nHistory fdn_write(0);\nHistory damp_state_0(0);\nHistory damp_state_1(0);\nHistory damp_state_2(0);\nHistory damp_state_3(0);\nHistory damp_state_4(0);\nHistory damp_state_5(0);\nHistory damp_state_6(0);\nHistory damp_state_7(0);\n\nPREDELAY_BUFFER = 65536;   // > 200 ms at 192 kHz\nDIFFUSER_BUFFER = 327680;  // > 1588 ms at 192 kHz\nFDN_BUFFER = 524288;       // > 2002 ms at 192 kHz\nTWO_PI = 6.283185307179586;\nMS_TO_SAMPLES = samplerate * 0.001;\nSMOOTH = MS_TO_SAMPLES*smooth_ms;\n\npredelay_ms_s = slide(predelay_ms, SMOOTH, SMOOTH);\nsize_s = slide(size, SMOOTH, SMOOTH);\ndecay_s_s = slide(decay_s, SMOOTH, SMOOTH);\ndamping_hz_s = slide(damping_hz, SMOOTH, SMOOTH);\ndamping_amount_s = slide(damping_amount, SMOOTH, SMOOTH);\ninput_gain_db_s = slide(input_gain_db, SMOOTH, SMOOTH);\ninput_lowshelf_hz_s = slide(input_lowshelf_hz, SMOOTH, SMOOTH);\ninput_lowshelf_db_s = slide(input_lowshelf_db, SMOOTH, SMOOTH);\ndiffusion_ratio_s = slide(diffusion_ratio, SMOOTH, SMOOTH);\nmod_depth_ms_s = slide(mod_depth_ms, SMOOTH, SMOOTH);\nmod_rate_hz_s = slide(mod_rate_hz, SMOOTH, SMOOTH);\nearly_level_s = slide(early_level, SMOOTH, SMOOTH);\nwidth_s = slide(width, SMOOTH, SMOOTH);\nmix_s = slide(mix, SMOOTH, SMOOTH);\nfreeze_s = slide(freeze, SMOOTH, SMOOTH);\n\nsample_rate = samplerate;\npredelay_samples = predelay_ms_s * MS_TO_SAMPLES;\ndiffuser_scale = size_s * diffusion_ratio_s;\nrt60_samples = max(decay_s_s * sample_rate, 1);\ndamping_coeff = exp((-TWO_PI * damping_hz_s) / sample_rate);\neffective_damping_coeff = damping_coeff * damping_amount_s;\nfreeze_input = 1 - freeze_s;\nfreeze_damping_coeff = effective_damping_coeff * freeze_input;\nfreeze_gain_target = 0.99995;\ninput_gain = pow(10, input_gain_db_s * 0.05);\nreverb_input_left, reverb_input_right = stereo_low_shelf(in1, in2, input_lowshelf_hz_s, input_lowshelf_db_s);\nreverb_input_left = reverb_input_left * input_gain;\nreverb_input_right = reverb_input_right * input_gain;\n\npoke(predelay_left, reverb_input_left, predelay_write);\npoke(predelay_right, reverb_input_right, predelay_write);\npredelayed_left = delay_read_linear(predelay_left, predelay_write, predelay_samples);\npredelayed_right = delay_read_linear(predelay_right, predelay_write, predelay_samples);\npredelay_write = wrap(predelay_write + 1, 0, PREDELAY_BUFFER);\n\ninput_mid = (predelayed_left + predelayed_right) * 0.7071067811865476;\ninput_side = (predelayed_left - predelayed_right) * 0.7071067811865476;\nseed_gain = 0.25;\ns0_0 = predelayed_left * seed_gain;\ns0_1 = predelayed_right * seed_gain;\ns0_2 = input_mid * seed_gain;\ns0_3 = input_side * seed_gain;\ns0_4 = -predelayed_left * seed_gain;\ns0_5 = -predelayed_right * seed_gain;\ns0_6 = -input_mid * seed_gain;\ns0_7 = -input_side * seed_gain;\n\ndiffuser_1_delay_ms_0 = 5.3;\ndiffuser_1_delay_ms_1 = 6.7;\ndiffuser_1_delay_ms_2 = 8.9;\ndiffuser_1_delay_ms_3 = 10.2;\ndiffuser_1_delay_ms_4 = 12.8;\ndiffuser_1_delay_ms_5 = 14.1;\ndiffuser_1_delay_ms_6 = 17.3;\ndiffuser_1_delay_ms_7 = 19.6;\nd1_0 = diffuser_1_delay_ms_0 * diffuser_scale * MS_TO_SAMPLES;\nd1_1 = diffuser_1_delay_ms_1 * diffuser_scale * MS_TO_SAMPLES;\nd1_2 = diffuser_1_delay_ms_2 * diffuser_scale * MS_TO_SAMPLES;\nd1_3 = diffuser_1_delay_ms_3 * diffuser_scale * MS_TO_SAMPLES;\nd1_4 = diffuser_1_delay_ms_4 * diffuser_scale * MS_TO_SAMPLES;\nd1_5 = diffuser_1_delay_ms_5 * diffuser_scale * MS_TO_SAMPLES;\nd1_6 = diffuser_1_delay_ms_6 * diffuser_scale * MS_TO_SAMPLES;\nd1_7 = diffuser_1_delay_ms_7 * diffuser_scale * MS_TO_SAMPLES;\n\npoke(diffuser_1_0, s0_0, diffuser_write_1);\npoke(diffuser_1_1, s0_1, diffuser_write_1);\npoke(diffuser_1_2, s0_2, diffuser_write_1);\npoke(diffuser_1_3, s0_3, diffuser_write_1);\npoke(diffuser_1_4, s0_4, diffuser_write_1);\npoke(diffuser_1_5, s0_5, diffuser_write_1);\npoke(diffuser_1_6, s0_6