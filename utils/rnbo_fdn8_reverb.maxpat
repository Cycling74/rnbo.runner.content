                                            },
                                            "classnamespace": "dsp.gen",
                                            "rect": [ 342.0, 100.0, 921.0, 907.0 ],
                                            "boxes": [
                                                {
                                                    "box": {
                                                        "maxclass": "newobj",
                                                        "text": "in 1 @comment left",
                                                        "patching_rect": [ 44.0, 23.0, 112.0, 22.0 ],
                                                        "numinlets": 0,
