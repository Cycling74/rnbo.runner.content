                                    "rnbo_uniqueid": "midiout_obj-9",
                                    "text": "midiout"
                                }
                            },
                            {
                                "box": {
                                    "code": "@state pads = new FixedUint8Array(32);\r\n@state color = [0, 1, 1];\r\n@state off_color = [0.5, 0.5, 0.5];\r\n@state major = [0, 2, 4, 5, 7, 9, 11, 12];\r\n@state root = 60;\r\n@state mode = 0;\r\n\r\nfunction init() {\r\n    updateLights();\r\n}\r\n\r\nfunction padToNote(pad_idx) {\r\n    let row = floor(pad_idx / 8);\r\n    let col = pad_idx % 8;\r\n    if (mode == 0) { // octave\r\n        return major[col] + 12 * row + root;\r\n    } else if (mode == 1) {\r\n        let scale_idx = col + row * 3;\r\n        let octave = floor(scale_idx / 7);\r\n        let scale_degree = scale_idx % 7;\r\n        return major[scale_degree] + octave * 12 + root;\r\n    } else {\r\n        return root + pad_idx;\r\n    }\r\n}\r\n\r\nfunction updateLights() {\r\n    for (let i = 0; i < 32; i++) {\r\n        let note = padToNote(i);\r\n        let c: list = ((note - root) % 12) == 0 ? color : off_color;\r\n        let s = pads[i] ? 1.0 : 0.3;\r\n        listout1 = [0, i, c[0] * s, c[1] * s, c[2] * s];\r\n    }\r\n}\r\n\r\nfunction in2(m) {\r\n    // flush\r\n    for (let i = 0; i < 32; i++) {\r\n        listout2 = [padToNote(i), 0];\r\n        pads[i] = 0;\r\n    }\r\n    mode = m;\r\n    updateLights();\r\n}\r\n\r\nfunction in3(r) {\r\n    // flush\r\n    for (let i = 0; i < 32; i++) {\r\n        listout2 = [padToNote(i), 0];\r\n        pads[i] = 0;\r\n    }\r\n    root = r;\r\n    updateLights();\r\n}\r\n\r\nlet note = padToNote(listin1[0]);\r\nlistout2 = [note, listin1[1]];\r\nfor (let i = 0; i < 32; i++) {\r\n    let nnote = padToNote(i);\r\n    if (note == nnote) {\r\n        pads[i] = listin1[1] ? 1 : 0;\r\n    }\r\n}\r\nupdateLights();",
                                    "fontface": 0,
                                    "fontname": "<Monospaced>",
                                    "fontsize": 12.0,
                                    "id": "obj-8",
                                    "maxclass": "codebox",
                                    "numinlets": 3,
                                    "numoutlets": 2,
                                    "outlettype": [ "", "" ],
                                    "patching_rect": [ 89.0, 204.0, 736.0, 533.0 ],
                                    "rnbo_classname": "codebox",
                                    "rnbo_extra_attributes": {
                                        "hot": 0,
                                        "nocache": 0,
                                        "code": "@state pads = new FixedUint8Array(32);\r\n@state color = [0, 1, 1];\r\n@state off_color = [0.5, 0.5, 0.5];\r\n@state major = [0, 2, 4, 5, 7, 9, 11, 12];\r\n@state root = 60;\r\n@state mode = 0;\r\n\r\nfunction init() {\r\n    updateLights();\r\n}\r\n\r\nfunction padToNote(pad_idx) {\r\n    let row = floor(pad_idx / 8);\r\n    let col = pad_idx % 8;\r\n    if (mode == 0) { // octave\r\n        return major[col] + 12 * row + root;\r\n    } else if (mode == 1) {\r\n        let scale_idx = col + row * 3;\r\n        let octave = floor(scale_idx / 7);\r\n        let scale_degree = scale_idx % 7;\r\n        return major[scale_degree] + octave * 12 + root;\r\n    } else {\r\n        return root + pad_idx;\r\n    }\r\n}\r\n\r\nfunction updateLights() {\r\n    for (let i = 0; i < 32; i++) {\r\n        let note = padToNote(i);\r\n        let c: list = ((note - root) % 12) == 0 ? color : off_color;\r\n        let s = pads[i] ? 1.0 : 0.3;\r\n        listout1 = [0, i, c[0] * s, c[1] * s, c[2] * s];\r\n    }\r\n}\r\n\r\nfunction in2(m) {\r\n    // flush\r\n    for (let i = 0; i < 32; i++) {\r\n        listout2 = [padToNote(i), 0];\r\n        pads[i] = 0;\r\n    }\r\n    mode = m;\r\n    updateLights();\r\n}\r\n\r\nfunction in3(r) {\r\n    // flush\r\n    for (let i = 0; i < 32; i++) {\r\n        listout2 = [padToNote(i), 0];\r\n        pads[i] = 0;\r\n    }\r\n    root = r;\r\n    updateLights();\r\n}\r\n\r\nlet note = padToNote(listin1[0]);\r\nlistout2 = [note, listin1[1]];\r\nfor (let i = 0; i < 32; i++) {\r\n    let nnote = padToNote(i);\r\n    if (note == nnote) {\r\n        pads[i] = listin1[1] ? 1 : 0;\r\n    }\r\n}\r\nupdateLights();",
                                        "safemath": 1
                                    },
